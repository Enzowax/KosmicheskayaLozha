<Window x:Class="KosmicheskayaLozha.Windows.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" Height="380" Width="440"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">
    <Border Style="{StaticResource Card}" Margin="16">
        <StackPanel>
            <TextBlock Text="📦 Оформление заказа" Style="{StaticResource PageTitle}"/>

            <!-- Итог -->
            <Border Background="#3D1060" CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Сумма заказа: " Foreground="{StaticResource SubtextBrush}"
                               FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotal" Foreground="{StaticResource AccentBrush}"
                               FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Дата доставки (не более 7 дней) -->
            <TextBlock Text="Удобная дата получения:" Style="{StaticResource FieldLabel}"/>
            <DatePicker x:Name="DpDelivery"
                        Foreground="{StaticResource TextBrush}"
                        SelectedDateChanged="DpDelivery_Changed"/>
            <TextBlock x:Name="TxtDateError" Foreground="{StaticResource DangerBrush}"
                       FontSize="11" Margin="0,2,0,0" Visibility="Collapsed"/>

            <!-- Способ оплаты -->
            <TextBlock Text="Способ оплаты:" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbPayment" Style="{StaticResource ModernComboBox}">
                <ComboBoxItem Content="Наличные" IsSelected="True"/>
                <ComboBoxItem Content="Карта"/>
                <ComboBoxItem Content="СБП"/>
            </ComboBox>

            <!-- Кнопки -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="✖ Отмена" Style="{StaticResource BackButton}"
                        Click="BtnCancel_Click"/>
                <Button Grid.Column="2" Content="✅ Заказать" Style="{StaticResource SuccessButton}"
                        Click="BtnOrder_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
