<Page x:Class="KosmicheskayaLozha.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}" Title="Корзина">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Button Content="← Назад" Style="{StaticResource BackButton}"
                        HorizontalAlignment="Left" Click="BtnBack_Click"/>
                <TextBlock Text="🛒 Корзина" Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Товары в корзине -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16">
            <WrapPanel x:Name="WpCart"/>
        </ScrollViewer>

        <!-- Итог и кнопка заказа -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Итого: " Foreground="{StaticResource SubtextBrush}"
                               FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotal" Foreground="{StaticResource AccentBrush}"
                               FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="Оформить заказ →" Style="{StaticResource SuccessButton}"
                        HorizontalAlignment="Right" FontSize="14"
                        Click="BtnOrder_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
