<Page x:Class="KosmicheskayaLozha.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}" Title="Вход">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад" Style="{StaticResource BackButton}"
                HorizontalAlignment="Left" Margin="16,12" Click="BtnBack_Click"/>

        <Border Grid.Row="1" Style="{StaticResource Card}"
                Width="380" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="🔐 Вход в аккаунт" Style="{StaticResource PageTitle}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Логин:" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtLogin" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Пароль:" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource ModernPasswordBox}"/>

                <TextBlock x:Name="TxtError" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"
                           Visibility="Collapsed"/>

                <Button Content="Войти" Style="{StaticResource PrimaryButton}"
                        Margin="0,16,0,0" Click="BtnLogin_Click"/>

                <TextBlock Foreground="{StaticResource SubtextBrush}" FontSize="11"
                           TextAlignment="Center" Margin="0,12,0,0">
                    Тестовые аккаунты: admin/admin123 · manager1/manager123
                    · master1/master123 · client1/client123
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
