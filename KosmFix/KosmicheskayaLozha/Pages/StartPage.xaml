<Page x:Class="KosmicheskayaLozha.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}"
      Title="Главная">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✨" FontSize="28" Margin="0,0,8,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Космическая ложа" Foreground="{StaticResource AccentBrush}"
                                   FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Салон красоты &amp; магазин косметики"
                                   Foreground="{StaticResource SubtextBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnProducts" Content="🛍 Товары"
                            Style="{StaticResource BackButton}"
                            Margin="0,0,8,0" Click="BtnProducts_Click"/>
                    <Button x:Name="BtnAccount" Content="👤 Аккаунт"
                            Style="{StaticResource BackButton}"
                            Margin="0,0,8,0" Click="BtnAccount_Click"
                            Visibility="Collapsed"/>
                    <Button x:Name="BtnLogin" Content="🔐 Войти"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnLogin_Click"/>
                    <Button x:Name="BtnLogout" Content="🚪 Выйти"
                            Style="{StaticResource DangerButton}"
                            Click="BtnLogout_Click" Visibility="Collapsed" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Тело страницы -->
        <Grid Grid.Row="1" Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель: фильтры и услуги -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Фильтры" Style="{StaticResource PageTitle}" FontSize="16"/>

                <TextBlock Text="Тип услуги:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbServiceFilter" Style="{StaticResource ModernComboBox}"
                          SelectionChanged="Filter_Changed"/>

                <TextBlock Text="Мастер:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbMasterFilter" Style="{StaticResource ModernComboBox}"
                          SelectionChanged="Filter_Changed"/>

                <Button Content="Сбросить фильтры" Style="{StaticResource BackButton}"
                        Margin="0,10,0,0" Click="BtnResetFilter_Click"/>

                <Separator Style="{StaticResource Divider}" Margin="0,16"/>

                <TextBlock Text="Выберите услугу" Style="{StaticResource PageTitle}" FontSize="16"/>
                <ListBox x:Name="LstServices"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="LstServices_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource PrimaryBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="12,8" Margin="0,3">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Foreground="{StaticResource AccentBrush}" FontSize="11">
                                        <Run Text="от "/>
                                        <Run Text="{Binding Price, StringFormat='{}{0:N0} ₽'}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background"    Value="Transparent"/>
                            <Setter Property="Padding"       Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </StackPanel>

            <!-- Правая панель: мастера и слоты -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Мастера -->
                <StackPanel Grid.Row="0" x:Name="PnlMasters">
                    <TextBlock x:Name="TxtMastersTitle" Text="Мастера"
                               Style="{StaticResource PageTitle}" FontSize="18"/>
                    <ListBox x:Name="LstMasters"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="LstMasters_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="16,12" Margin="0,0,12,12" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="👩‍🎨" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding FullName}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                        <TextBlock Text="{Binding Phone}"
                                                   Foreground="{StaticResource SubtextBrush}"
                                                   FontSize="11" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background"    Value="Transparent"/>
                                <Setter Property="Padding"       Value="0"/>
                                <Setter Property="Cursor"        Value="Hand"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>

                <!-- Слоты записи -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PnlSlots">
                        <TextBlock x:Name="TxtSlotsTitle" Text=""
                                   Style="{StaticResource PageTitle}" FontSize="16"/>
                        <WrapPanel x:Name="WpSlots"/>
                        <TextBlock x:Name="TxtNoSlots" Text="Нет доступных записей"
                                   Foreground="{StaticResource SubtextBrush}"
                                   FontSize="14" Margin="0,20" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
