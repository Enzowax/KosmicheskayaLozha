<Window x:Class="KosmicheskayaLozha.Windows.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="540" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Style="{StaticResource Card}" Margin="16">
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Style="{StaticResource PageTitle}" FontSize="18"/>

                <TextBlock Text="Название:" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtName" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Цена (₽):" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtPrice" Style="{StaticResource ModernTextBox}"/>

                <TextBlock Text="Скидка (%, 0–99):" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDiscount" Style="{StaticResource ModernTextBox}" Text="0"/>

                <TextBlock Text="Рейтинг (0.0–5.0):" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtRating" Style="{StaticResource ModernTextBox}" Text="0"/>

                <TextBlock Text="Производитель:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbManufacturer" Style="{StaticResource ModernComboBox}"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Тип товара:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbType" Style="{StaticResource ModernComboBox}"
                          DisplayMemberPath="Name"/>

                <TextBlock Text="Описание:" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtDesc" Style="{StaticResource ModernTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock x:Name="TxtError" Foreground="{StaticResource DangerBrush}"
                           FontSize="11" Margin="0,6,0,0" Visibility="Collapsed"/>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="✖ Отмена" Style="{StaticResource BackButton}"
                            Click="BtnCancel_Click"/>
                    <Button Grid.Column="2" Content="💾 Сохранить" Style="{StaticResource SuccessButton}"
                            Click="BtnSave_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</Window>
