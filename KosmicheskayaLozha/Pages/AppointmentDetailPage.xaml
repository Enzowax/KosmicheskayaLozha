<Page x:Class="KosmicheskayaLozha.Pages.AppointmentDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}" Title="Запись">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Button Content="← Назад" Style="{StaticResource BackButton}"
                        HorizontalAlignment="Left" Click="BtnBack_Click"/>
                <TextBlock Text="📅 Запись на сеанс" Foreground="{StaticResource AccentBrush}"
                           FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}"
                Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Информация о записи" Style="{StaticResource PageTitle}" FontSize="18"/>

                <!-- Инфо о записи -->
                <Border Background="#3D1060" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="💅 Услуга:"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtService"
                                   Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="👩‍🎨 Мастер:"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,12,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtMaster"
                                   Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="🕐 Дата:"
                                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,12,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtDate"
                                   Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="15"/>
                    </Grid>
                </Border>

                <!-- Цена -->
                <TextBlock x:Name="TxtPrice" Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,12"/>

                <!-- Способ оплаты -->
                <TextBlock Text="Способ оплаты:" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbPayment" Style="{StaticResource ModernComboBox}">
                    <ComboBoxItem Content="Наличные"    IsSelected="True"/>
                    <ComboBoxItem Content="Карта"/>
                    <ComboBoxItem Content="СБП"/>
                </ComboBox>

                <!-- Комментарий -->
                <TextBlock Text="Комментарий (необязательно):" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtComment" Style="{StaticResource ModernTextBox}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <Button Content="✅ Записаться" Style="{StaticResource SuccessButton}"
                        Margin="0,16,0,0" FontSize="15" Click="BtnBook_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
