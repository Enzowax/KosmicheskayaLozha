<Page x:Class="KosmicheskayaLozha.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}" Title="Администратор">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Button Content="🚪 Выйти" Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Left" Click="BtnLogout_Click"/>
                <TextBlock x:Name="TxtTitle" Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="➕ Добавить пользователя" Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0" Click="BtnAddUser_Click"/>
                <Button Content="✏ Изменить" Style="{StaticResource BackButton}"
                        Margin="0,0,8,0" Click="BtnEditUser_Click"/>
                <Button Content="❄ Заморозить / 🔥 Разморозить" Style="{StaticResource BackButton}"
                        Click="BtnFreezeUser_Click"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="DgUsers"
                      Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeRows="False" RowHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"       Binding="{Binding Id}"        Width="40"/>
                    <DataGridTextColumn Header="Логин"    Binding="{Binding Login}"      Width="120"/>
                    <DataGridTextColumn Header="Фамилия"  Binding="{Binding LastName}"   Width="130"/>
                    <DataGridTextColumn Header="Имя"      Binding="{Binding FirstName}"  Width="110"/>
                    <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="130"/>
                    <DataGridTextColumn Header="Телефон"  Binding="{Binding Phone}"      Width="130"/>
                    <DataGridTextColumn Header="Роль"     Binding="{Binding RoleName}"   Width="100"/>
                    <DataGridCheckBoxColumn Header="Заморожен" Binding="{Binding IsFrozen}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
