<Page x:Class="KosmicheskayaLozha.Pages.MasterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}" Title="Мастер">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Button Content="🚪 Выйти" Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Left" Click="BtnLogout_Click"/>
                <TextBlock x:Name="TxtTitle" Foreground="{StaticResource AccentBrush}"
                           FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Мои услуги -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Мои услуги" Style="{StaticResource PageTitle}" FontSize="16"/>
                <TextBlock Text="Отметьте услуги, которые вы оказываете:"
                           Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,0,0,8"/>
                <ListBox x:Name="LstAllServices"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource PrimaryBrush}"
                                    BorderThickness="1" CornerRadius="5"
                                    Padding="10,7" Margin="0,2">
                                <CheckBox x:Name="ChkService"
                                          IsChecked="{Binding IsChecked}"
                                          Foreground="{StaticResource TextBrush}"
                                          FontSize="13">
                                    <TextBlock>
                                        <Run Text="{Binding ServiceType.Name}"/>
                                        <Run Text=" — " Foreground="{StaticResource SubtextBrush}"/>
                                        <Run Text="{Binding ServiceType.Price, StringFormat='{}{0:N0} ₽'}"
                                             Foreground="{StaticResource AccentBrush}"/>
                                    </TextBlock>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding"    Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
                <Button Content="💾 Сохранить услуги" Style="{StaticResource SuccessButton}"
                        Margin="0,10,0,0" Click="BtnSaveServices_Click"/>
            </StackPanel>

            <!-- Мои записи -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Мои записи" Style="{StaticResource PageTitle}" FontSize="16"/>
                <DataGrid x:Name="DgAppointments"
                          Style="{StaticResource ModernDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserResizeRows="False" RowHeight="38"
                          MouseDoubleClick="DgAppointments_DoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата и время" Binding="{Binding DateTimeStr}"      Width="130"/>
                        <DataGridTextColumn Header="Услуга"        Binding="{Binding ServiceTypeName}" Width="*"/>
                        <DataGridTextColumn Header="Клиент"        Binding="{Binding ClientFullName}"  Width="180"/>
                        <DataGridTextColumn Header="Статус"        Binding="{Binding StatusText}"      Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="Дважды кликните на запись для просмотра деталей"
                           Foreground="{StaticResource SubtextBrush}" FontSize="11" Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
